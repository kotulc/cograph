{
  "name": "@cograph/renderer",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "dev": "vite --config vite.dev.config.ts"
  },
  "peerDependencies": {
    "react": "^18",
    "react-dom": "^18"
  },
  "dependencies": {
    "@cograph/core": "workspace:*",
    "chroma-js": "^2.4.2",
    "cytoscape": "^3.29.2",
    "cytoscape-fcose": "^2.2.0",
    "cytoscape-compound-drag-and-drop": "^1.0.0"
  },
  "devDependencies": {
    "@types/chroma-js": "^2.4.4",
    "@types/cytoscape": "^3.21.8",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^25",
    "react": "^18",
    "react-dom": "^18",
    "vite": "^5",
    "vite-plugin-dts": "^4",
    "vitest": "^2",
    "typescript": "^5.5"
  }
